{
  "name": "yoga-graph-api",
  "version": "0.1.0",
  "description": "A GraphQL API built with GraphQL Yoga, Fastify, Pothos, and Prisma.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --include \"src/**/*.ts\" src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint --fix .",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepare": "husky"
  },
  "keywords": [
    "graphql",
    "graphql-yoga",
    "fastify",
    "pothos",
    "prisma",
    "api"
  ],
  "author": "AutanaSoft",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AutanaSoft/yoga-graph-api.git"
  },
  "homepage": "https://github.com/AutanaSoft/yoga-graph-api#readme",
  "bugs": {
    "url": "https://github.com/AutanaSoft/yoga-graph-api/issues"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/csrf-protection": "^7.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.0.0",
    "@graphql-tools/merge": "^9.1.7",
    "@pothos/core": "^4.12.0",
    "@pothos/plugin-complexity": "^4.1.2",
    "@pothos/plugin-prisma": "^4.14.2",
    "@pothos/plugin-prisma-utils": "^1.3.3",
    "@pothos/plugin-scope-auth": "^4.1.6",
    "@pothos/plugin-validation": "^4.2.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.4",
    "fastify-plugin": "^5.1.0",
    "fs-extra": "^11.3.4",
    "graphql": "^16.13.2",
    "graphql-yoga": "^5.18.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  }
}
