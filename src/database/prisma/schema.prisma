generator client {
  provider            = "prisma-client"
  output              = "./generated"
  moduleFormat        = "cjs"
  importFileExtension = "js"
  binaryTargets       = ["native", "rhel-openssl-3.0.x"]
}

generator pothos {
  provider     = "prisma-pothos-types"
  clientOutput = "./"
  output       = "./generated/pothos-prisma-types.ts"
}

datasource db {
  provider = "postgresql"
}
